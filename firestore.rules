rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read store phone routing lookup
    match /store_phones/{phone} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Allow Functions to access error logs and analytics
    match /error-logs/{document=**} {
      allow read, write: if true;
    }
    
    match /sms-analytics/{document=**} {
      allow read, write: if true;
    }
    
    // Allow public read for customer workorder PIN lookups
    match /workorder-pins/{pin} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow read/write access to authenticated users for all other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}