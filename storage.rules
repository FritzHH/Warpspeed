rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Tenant-scoped file access
    match /{tenantID}/{storeID}/{allPaths=**} {
      allow read, write: if request.auth != null
                      && request.auth.token.tenantID == tenantID
                      && request.auth.token.storeID == storeID;
    }
  }
}
