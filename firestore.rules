rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────
    // Claim shapes supported:
    //   Bonita (legacy):  { tenantID, storeID }
    //   SaaS:             { tenantID, privilege, stores: [storeID, ...] }
    //                     { platformAdmin: true }  (cross-tenant operator)
    //
    // Use token.get(key, default) to read fields that may not exist on
    // every user, so the rule doesn't throw on legacy users.

    function isAuthed() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isAuthed()
          && request.auth.token.get('platformAdmin', false) == true;
    }

    function isTenantMember(tenantID) {
      return isAuthed()
          && request.auth.token.get('tenantID', '') == tenantID;
    }

    function isOwner(tenantID) {
      return isTenantMember(tenantID)
          && request.auth.token.get('privilege', '') == 'owner';
    }

    // Store-level access: owner of the tenant (all stores), OR storeID is
    // in the new `stores` array claim, OR the legacy singular `storeID`
    // claim matches. Bonita users keep working without re-claiming.
    function hasStoreAccess(tenantID, storeID) {
      return isTenantMember(tenantID)
          && (
                isOwner(tenantID)
             || storeID in request.auth.token.get('stores', [])
             || request.auth.token.get('storeID', '') == storeID
          );
    }

    // ── Tenant-scoped data ─────────────────────────────────────
    // Store data is the bulk of the app. Members of the store (or tenant
    // owners) get full read/write access. The app does direct Firestore
    // writes for speed; mutations are not callable-gated.
    //
    // Exception: settings/settings has a short list of protected fields
    // (auth-sensitive + money-sensitive). On SaaS, non-admin writes are
    // allowed only if NONE of those fields changed. Admin/owner can change
    // anything. Bonita users (no privilege claim) retain legacy
    // unrestricted writes — Bonita is out of scope here.
    //
    // Protected fields list lives in settingsProtectedFieldsUnchanged
    // below; update both rule + the matching tenant-app memory note if
    // the list changes.
    match /tenants/{tenantID}/stores/{storeID} {
      match /{collection}/{document=**} {
        allow read, write: if hasStoreAccess(tenantID, storeID)
                           && collection != 'settings';
      }
      match /settings/{docID=**} {
        allow read: if hasStoreAccess(tenantID, storeID);
        allow write: if hasStoreAccess(tenantID, storeID) && (
          // Bonita: no privilege claim → unchanged
          request.auth.token.get('privilege', '') == ''
          // SaaS admin/owner: full access
          || request.auth.token.get('privilege', '') in ['admin', 'owner']
          // SaaS non-admin: only if protected fields are unchanged
          || settingsProtectedFieldsUnchanged(request.resource, resource)
        );
      }
    }

    function settingsProtectedFieldsUnchanged(req, res) {
      return req.data.users == res.data.users
          && req.data.cardFeePercent == res.data.cardFeePercent
          && req.data.useCardFee == res.data.useCardFee
          && req.data.userPinStrength == res.data.userPinStrength
          && req.data.adminAuthLogout == res.data.adminAuthLogout
          && req.data.faceRecognitionThreshold == res.data.faceRecognitionThreshold;
    }

    // Tenant document + non-store subcollections (e.g. connect-accounts,
    // billing config). Tenant members can read; only platform-admins write
    // these directly. Owner-scoped writes happen via callables (which have
    // their own assertPrivilege checks), so direct-write is off for safety.
    match /tenants/{tenantID} {
      allow read: if isTenantMember(tenantID) || isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    // Tenant-level Gmail collections: members read/write directly (app
    // does fast Firestore writes for inbox/account state; Cloud Functions
    // also write via Admin SDK which bypasses rules).
    match /tenants/{tenantID}/email-accounts/{docID=**} {
      allow read, write: if isTenantMember(tenantID);
    }
    match /tenants/{tenantID}/email-auth/{docID=**} {
      allow read, write: if isTenantMember(tenantID);
    }
    match /tenants/{tenantID}/emails/{docID=**} {
      allow read, write: if isTenantMember(tenantID);
    }

    match /tenants/{tenantID}/{collection}/{docID=**} {
      // /stores/** is handled by the deeper match above and reaches here
      // only via this catch-all for other tenant-level collections.
      allow read: if collection != 'stores'
                   && (isTenantMember(tenantID) || isPlatformAdmin());
      allow write: if collection != 'stores' && isPlatformAdmin();
    }

    // ── Platform-only top-level collections ────────────────────
    // Routing caches and idempotency records — Cloud Functions only.
    match /connect-accounts-index/{stripeAccountID} {
      allow read, write: if false;
    }
    match /payment-intents/{piID} {
      allow read, write: if false;
    }
    match /checkout-sessions/{sessionID} {
      allow read, write: if false;
    }
    match /processed-events/{eventID} {
      allow read, write: if false;
    }
    match /dlq-escalations/{escalationID} {
      allow read, write: if false;
    }

    // Billing tier catalog — any authed user can read so tenant-side UI can
    // display its assigned tier's label and monthly amount. Writes are
    // platform-admin only via the tier-management callables.
    match /platform-billing-tiers/{tierID} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // Vendor catalogs (JBI, etc.) — public read so Bonita's cross-project
    // secondary-app can read without auth ceremony. Data is non-sensitive
    // (sourced from each vendor's public FTP). Writes are blocked entirely;
    // the Cloud Run sync jobs use the Admin SDK which bypasses rules.
    match /vendor_catalogs/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // DLQ entries — platform-admin can read for the admin UI. Writes only
    // happen via the ingestor + admin callables (Cloud Functions).
    match /saas-dlq/{dlqEntryID} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }
    match /saas-twilio-dlq/{dlqEntryID} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    // Invites — fully server-only. Redemption goes through redeemInvite
    // callable; listing pending invites happens through a future callable
    // so the token isn't exposed to clients beyond the original recipient.
    match /invites/{token} {
      allow read, write: if false;
    }

    // ── Legacy auth lookup tables ──────────────────────────────
    match /users/{userID} {
      allow read: if isAuthed() && request.auth.uid == userID;
      allow write: if false;
    }
    match /email_users/{userID} {
      allow read: if isAuthed() && request.auth.uid == userID;
      allow write: if false;
    }
    match /store_phones/{phone} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // ── Server-only diagnostics ────────────────────────────────
    match /error-logs/{document=**} {
      allow read, write: if false;
    }
    match /sms-analytics/{document=**} {
      allow read, write: if false;
    }
  }
}
