rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: caller belongs to this tenant
    function isTenantMember(tenantID) {
      return request.auth != null
          && request.auth.token.tenantID == tenantID;
    }

    // Helper: caller belongs to this tenant AND store
    function isStoreMember(tenantID, storeID) {
      return isTenantMember(tenantID)
          && request.auth.token.storeID == storeID;
    }

    // ── Tenant-scoped data (primary security boundary) ──
    match /tenants/{tenantID}/stores/{storeID}/{document=**} {
      allow read, write: if isStoreMember(tenantID, storeID);
    }

    // Tenant-level docs (e.g. tenant metadata) - any member of the tenant
    match /tenants/{tenantID} {
      allow read: if isTenantMember(tenantID);
      allow write: if false;
    }

    // ── Global user index (login lookup by UID) ──
    match /users/{userID} {
      allow read: if request.auth != null && request.auth.uid == userID;
      allow write: if false;
    }

    // ── Store phone routing (authenticated read, write by Cloud Functions only) ──
    match /store_phones/{phone} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Workorder PINs (customer-facing, authenticated write) ──
    match /workorder-pins/{pin} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Error logs and SMS analytics (Cloud Functions admin SDK only) ──
    match /error-logs/{document=**} {
      allow read, write: if false;
    }

    match /sms-analytics/{document=**} {
      allow read, write: if false;
    }
  }
}
